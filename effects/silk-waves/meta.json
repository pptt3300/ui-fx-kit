{
  "name": "Silk Waves",
  "description": "Layered silk-like wave strands rendered via WebGL with mouse-reactive distortion and Perlin noise displacement.",
  "category": ["background", "interactive", "webgl"],
  "framework": "react",
  "runtime": ["webgl", "pointer-events"],
  "complexity": "high",
  "performance_cost": "high",
  "mobile_safe": false,
  "accessibility_notes": ["purely decorative — hide from assistive tech", "needs reduced-motion fallback"],
  "dependencies": [],
  "files": ["SilkWaves.tsx"],
  "imports": ["react", "../../presets/colors"],
  "hooks": [],
  "css": [],
  "presets": ["colors"],
  "props_schema": {
    "strandCount": { "type": "number", "default": 5, "range": [1, 5], "description": "Number of wave strands" },
    "amplitude": { "type": "number", "default": 50, "range": [10, 200], "description": "Wave displacement amplitude in px" },
    "mouseReactive": { "type": "boolean", "default": true, "description": "Whether waves distort near the cursor" },
    "palette": {
      "type": "enum",
      "options": ["default", "neon", "pastel", "warm", "arctic", "mono", "stripe", "vercel", "linear", "supabase", "figma", "discord", "spotify"],
      "description": "Color theme name from presets"
    },
    "className": { "type": "string", "description": "CSS class for the canvas element" }
  },
  "use_cases": ["hero section background", "ambient dashboard decoration", "creative portfolio backdrop", "SaaS landing page"],
  "conflicts": ["WebGL not supported on all devices", "continuous GPU draw — battery drain on mobile", "strandCount clamped to 5 in shader"]
}
